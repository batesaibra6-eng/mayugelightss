# ============================================================
#  Mayuge Light SS — Frontend Environment Variables
#  Copy to ".env" and set the correct API URL for production.
# ============================================================

# During local development, leave this unset — Vite proxies /api
# to the Express server running on http://localhost:5000 (see vite.config.js).

# For production, set this to your deployed backend URL, e.g.:
# VITE_API_URL=https://mayuge-light-ss-api.onrender.com/api
VITE_API_URL=/api
