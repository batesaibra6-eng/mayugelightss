# ============================================================
#  Mayuge Light Secondary School — Backend Environment Config
#  Copy this file to ".env" and fill in real values.
# ============================================================

# Environment: development | production
NODE_ENV=development

# Server port (Render sets PORT automatically)
PORT=5000

# MongoDB connection string (MongoDB Atlas for production)
# Local example:  mongodb://127.0.0.1:27017/mayuge_light_ss
# Atlas example:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/mayuge_light_ss
MONGO_URI=mongodb://127.0.0.1:27017/mayuge_light_ss

# JWT settings
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins for CORS
# In production, add your Render frontend URL here, e.g.
# CLIENT_URL=https://mayuge-light-ss-client.onrender.com,https://mayugelightss.onrender.com
CLIENT_URL=http://localhost:5173,http://localhost:4173

# Default admin account created by `npm run seed`
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@mayugelightss.sc.ug
ADMIN_PASSWORD=ChangeMe123!
